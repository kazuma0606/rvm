pub fn runtime_handler(req: Request<string>) -> Response<string>! {
    let js = "/* forge.min.js not yet built — run: forge build --web examples/anvil-bloom-ssr */"
    ok(Response::text(js).header("Content-Type", "text/javascript; charset=utf-8"))
}
