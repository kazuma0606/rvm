use anvil/request.*
use anvil/response.*
use bloom/ssr.{ render_source, hydrate_inline_script }

fn page_layout(content: string, script: string) -> string {
    "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Anvil + Bloom SSR</title></head><body><div id=\"app\">{content}</div>{script}</body></html>"
}

pub fn index_handler(req: Request<string>) -> Response<string>! {
    let html = "<h1>Anvil + Bloom SSR</h1><p>Visit <a href=\"/counter\">/counter</a> to see the counter.</p>"
    ok(Response::html(page_layout(html, "")))
}

