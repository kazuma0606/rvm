use bloom/ssr.{ render_source, hydrate_inline_script }

test "counter page SSR renders html with Counter heading" {
    let html = render(<CounterPage />)
    assert(html.contains("Counter"))
}

test "counter page SSR renders buttons with event attributes" {
    let html = render(<CounterPage />)
    assert(html.contains("data-on-click"))
}

test "counter page SSR renders reactive count span" {
    let html = render(<CounterPage />)
    assert(html.contains("data-reactive"))
}

test "counter page hydrate script contains inline script tag" {
    let script = hydrate_inline_script(<CounterPage />)
    assert(script.contains("<script>"))
    assert(script.contains("</script>"))
}

test "counter page hydrate script contains bloom update function" {
    let script = hydrate_inline_script(<CounterPage />)
    assert(script.contains("__bloom_update"))
}
