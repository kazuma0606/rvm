use anvil/ssr.{ layout }
use bloom/ssr.{ render_source, hydrate_script_with }

test "anvil bloom example: counter route renders SSR html" {
    let html = render(<CounterPage />)
    let script = hydrate_script_with("/components/counter_page.wasm")
    let doc = layout(html, script)
    assert(doc.contains("Counter"))
    assert(doc.contains("/forge.min.js"))
    assert(doc.contains("/components/counter_page.wasm"))
}

test "anvil bloom example: hydrate script targets component wasm" {
    let script = hydrate_script_with("/components/counter_page.wasm")
    assert(script.contains("forge.min.js"))
    assert(script.contains("/components/counter_page.wasm"))
}
