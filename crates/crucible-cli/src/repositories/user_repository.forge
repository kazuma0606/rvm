struct UserRepository {
    conn: Conn
}

fn new_user_repository(conn: Conn) -> UserRepository {
    UserRepository { conn: conn }
}

fn find_all(repo: UserRepository) -> list<map>! {
    all_rows(repo.conn, "users")
}

fn find_by_id(repo: UserRepository, id: number) -> map! {
    find_by_id(repo.conn, "users", id)
}
