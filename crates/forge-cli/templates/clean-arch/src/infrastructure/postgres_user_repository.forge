use ./domain/user.*

pub struct PostgresUserRepository {
    url: string
}

pub fn new_postgres_user_repository(url: string) -> PostgresUserRepository {
    PostgresUserRepository {
        url: url,
    }
}

pub fn repository_status(repo: PostgresUserRepository) -> string {
    "repository ready: {repo.url}"
}

pub fn save_user(repo: PostgresUserRepository, user: User) -> User! {
    println("saving {user.email} with {repo.url}")
    ok(user)
}
