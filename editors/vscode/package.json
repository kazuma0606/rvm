{
  "name": "forge-vscode",
  "displayName": "ForgeScript",
  "description": "VS Code support for ForgeScript via forge-lsp.",
  "version": "0.1.0",
  "publisher": "forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuma0606/rvm.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "files": [
    "out/**",
    "notebook-renderers/**",
    "syntaxes/**",
    "language-configuration.json",
    "package.json"
  ],
  "categories": [
    "Programming Languages",
    "Notebooks"
  ],
  "activationEvents": [
    "onLanguage:forge",
    "onNotebook:fnb",
    "onDebug",
    "onDebugResolve:forge",
    "onDebugDynamicConfigurations:forge"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "ForgeScript",
          "forge"
        ],
        "extensions": [
          ".forge"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forge",
        "scopeName": "source.forge",
        "path": "./syntaxes/forge.tmLanguage.json"
      }
    ],
    "notebooks": [
      {
        "type": "fnb",
        "displayName": "Forge Notebook",
        "selector": [
          {
            "filenamePattern": "*.fnb"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "forge-output-renderer",
        "displayName": "Forge Notebook Output Renderer",
        "entrypoint": "./out/notebook/pipeline-trace-renderer.js",
        "mimeTypes": [
          "application/vnd.forge.table+json",
          "application/vnd.forge.html+json",
          "application/vnd.forge.pipeline-trace+json"
        ]
      }
    ],
    "breakpoints": [
      { "language": "forge" },
      { "language": "bloom" }
    ],
    "debuggers": [
      {
        "type": "forge",
        "label": "ForgeScript Debug",
        "languages": ["forge"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the ForgeScript entry point (.forge file)",
                "default": "${workspaceFolder}/src/main.forge"
              },
              "mode": {
                "type": "string",
                "enum": ["run", "serve"],
                "default": "run",
                "description": "Execution mode: 'run' for scripts, 'serve' for Anvil HTTP server"
              },
              "port": {
                "type": "number",
                "default": 8080,
                "description": "Port number when mode is 'serve'"
              },
              "dapPath": {
                "type": "string",
                "default": "forge-dap",
                "description": "Path to the forge-dap binary. Defaults to 'forge-dap' (must be in PATH)."
              },
              "noDebug": {
                "type": "boolean",
                "default": false,
                "description": "Run without debug adapter (no breakpoints)"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "forge",
            "request": "launch",
            "name": "Run ForgeScript",
            "program": "${workspaceFolder}/src/main.forge"
          }
        ],
        "configurationSnippets": [
          {
            "label": "ForgeScript: Run",
            "description": "Run a ForgeScript file",
            "body": {
              "type": "forge",
              "request": "launch",
              "name": "Run ForgeScript",
              "program": "^\"\\${workspaceFolder}/src/main.forge\""
            }
          },
          {
            "label": "ForgeScript: Serve (Anvil debug)",
            "description": "Start Anvil HTTP server with debugging",
            "body": {
              "type": "forge",
              "request": "launch",
              "name": "Serve Anvil (debug)",
              "program": "^\"\\${workspaceFolder}/src/main.forge\"",
              "mode": "serve",
              "port": 8080
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "ForgeScript",
      "properties": {
        "forge.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Command or executable path for the language server. If you point to `forge-lsp`, it is launched directly. Otherwise the extension runs `<path> lsp`."
        },
        "forge.notebook.path": {
          "type": "string",
          "default": "",
          "description": "Command or executable path for notebook execution. The extension runs `<path> notebook --kernel`."
        },
        "forge.dap.path": {
          "type": "string",
          "default": "forge-dap",
          "description": "Path to the forge-dap binary for DAP debugging. Defaults to 'forge-dap' (must be in PATH)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.5.4"
  }
}
