{
  "name": "forge-vscode",
  "displayName": "ForgeScript",
  "description": "VS Code support for ForgeScript via forge-lsp.",
  "version": "0.1.0",
  "publisher": "forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuma0606/rvm.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "files": [
    "out/**",
    "notebook-renderers/**",
    "syntaxes/**",
    "language-configuration.json",
    "package.json"
  ],
  "categories": [
    "Programming Languages",
    "Notebooks"
  ],
  "activationEvents": [
    "onLanguage:forge",
    "onNotebook:fnb"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "ForgeScript",
          "forge"
        ],
        "extensions": [
          ".forge"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forge",
        "scopeName": "source.forge",
        "path": "./syntaxes/forge.tmLanguage.json"
      }
    ],
    "notebooks": [
      {
        "type": "fnb",
        "displayName": "Forge Notebook",
        "selector": [
          {
            "filenamePattern": "*.fnb"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "forge-output-renderer",
        "displayName": "Forge Notebook Output Renderer",
        "entrypoint": "./out/notebook/pipeline-trace-renderer.js",
        "mimeTypes": [
          "application/vnd.forge.table+json",
          "application/vnd.forge.html+json",
          "application/vnd.forge.pipeline-trace+json"
        ]
      }
    ],
    "configuration": {
      "title": "ForgeScript",
      "properties": {
        "forge.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Command or executable path for the language server. If you point to `forge-lsp`, it is launched directly. Otherwise the extension runs `<path> lsp`."
        },
        "forge.notebook.path": {
          "type": "string",
          "default": "",
          "description": "Command or executable path for notebook execution. The extension runs `<path> notebook --kernel`."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.5.4"
  }
}
